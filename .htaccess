# Rediriger tout le trafic vers Passenger (Django)
PassengerEnabled On
PassengerAppRoot /home/tumxxzse/ista-gm
PassengerPython /home/tumxxzse/virtualenv/ista-gm/3.9/bin/python

# Fichiers statiques servis directement par Apache
RewriteEngine On
RewriteCond %{REQUEST_URI} !^/static/
RewriteCond %{REQUEST_URI} !^/media/
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
